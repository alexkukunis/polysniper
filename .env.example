# ── Database ──────────────────────────────
# Railway will provide this automatically when you add PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/botdb

# ── Polymarket API ────────────────────────
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_PASSPHRASE=your_passphrase
WALLET_PRIVATE_KEY=your_private_key_here

# ── Blockchain (Polygon) ──────────────────
# Get from https://www.alchemy.com/ or https://infura.io/
POLYGON_RPC=https://polygon-rpc.com
POLYGON_WSS_RPC=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Bot Config ────────────────────────────
BANKROLL_USDC=1000
PAPER_MODE=true

# ── Alerts ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
